# ────────────────────────────────────────────────────────────────────────────
# MOTELSBRASIL — VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env.local e preencha os valores
# ────────────────────────────────────────────────────────────────────────────

# ── SUPABASE ─────────────────────────────────────────────────────────────────
# Dashboard Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Nunca exponha no frontend — apenas em API routes / Server Components
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── GOOGLE MAPS ───────────────────────────────────────────────────────────────
# console.cloud.google.com → APIs → Maps JavaScript + Places + Geocoding
# Restrinja a chave ao seu domínio em produção
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...

# ── PAYPAL ────────────────────────────────────────────────────────────────────
# developer.paypal.com → My Apps & Credentials → Create App
# Sandbox para testes, Live para produção
NEXT_PUBLIC_PAYPAL_CLIENT_ID=AQ...
PAYPAL_CLIENT_SECRET=EJ...
PAYPAL_MODE=sandbox
# Crie o plano em: PayPal Dashboard → Products & Plans
# Produto: "Site Motel MotéisBrasil" / Plano: R$50 BRL mensal recorrente
NEXT_PUBLIC_PAYPAL_PLAN_ID=P-...
PAYPAL_PLAN_ID=P-...

# ── SITE ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Em produção: https://motelsbrasil.com.br
